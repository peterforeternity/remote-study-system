# ============================================================
# 远程指导学习系统 环境变量示例
# 复制为 .env 后填入真实值。切勿把 .env 提交到仓库。
# ============================================================

# --- 前端可见（浏览器）变量：仅可放公开信息 ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- 服务端专用密钥：禁止使用 VITE_ 前缀，禁止进入前端代码 ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- AI Worker 配置（服务端）---
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=
APP_BASE_URL=http://localhost:5173
